# Basic config
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
POSTGRES_DB=gestion_magasin_db
POSTGRES_USER=gestion_magasin_user
POSTGRES_PASSWORD=gestion_magasin_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5437

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Local
API_URL=http://127.0.0.1:8006
FRONTEND_URL=http://localhost:3006

# E.B.H SSO
EBH_SSO_APP_SLUG=gestion_magasin
EBH_SSO_VERIFY_URL=http://localhost:8004/api/account/sso/verify/
